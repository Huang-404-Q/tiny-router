{
  "name": "tiny-router",
  "version": "0.1.0",
  "description": "Tiny Anthropic-compatible self-routing gateway for Claude Code experiments.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claude-router": "bin/claude-router.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "check": "node --check src/server.js && node --check tests/fake-upstream.test.js",
    "test": "node tests/fake-upstream.test.js && node tests/multi-client.test.js",
    "claude:router": "powershell -ExecutionPolicy Bypass -File scripts/claude-router.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "tests",
    "scripts",
    "bin",
    "router.config.example.json",
    "README.md",
    "LICENSE"
  ]
}
